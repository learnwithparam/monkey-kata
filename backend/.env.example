# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=True

# CORS Settings
FRONTEND_URL=http://localhost:3000

# LLM Provider Configuration (REQUIRED)
# Set the default text LLM provider: "fireworks", "openrouter", "gemini", "openai"
LLM_PROVIDER=fireworks

# Image Generation Provider (optional - for Image to Coloring Book converter)
# Supports: "fireworks" (FLUX), "openai" (DALL-E)
# If not set, uses the default LLM_PROVIDER
IMAGE_LLM_PROVIDER=fireworks

# Vision/Multimodal Provider (optional - for Invoice Parser and other vision demos)
# Supports: "gemini" (recommended for PDF), "openai" (GPT-4o), "fireworks" (Qwen-VL)
# If not set, uses the default LLM_PROVIDER
VISION_LLM_PROVIDER=gemini

# FireworksAI (recommended for best performance)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_MODEL=accounts/fireworks/models/qwen3-235b-a22b-instruct-2507

# OpenRouter (access to many models including Claude, GPT-4, Llama, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=minimax/minimax-m2:free
# Optional: Set these for better analytics and support
# OPENROUTER_HTTP_REFERER=https://your-app-url.com
# OPENROUTER_APP_NAME=AI Engineering by Param Harrison

# Google Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini

# RAG Configuration
# Embedding model for semantic search (local model for cost efficiency)
EMBEDDING_MODEL=all-MiniLM-L6-v2
# Alternative models: all-mpnet-base-v2, all-distilroberta-v1, paraphrase-multilingual-MiniLM-L12-v2

# LiveKit Configuration (Required for Restaurant Booking Voice AI demo)
# Get your credentials from: https://livekit.cloud (cloud) or deploy self-hosted
# See: https://docs.livekit.io/deploy/ for self-hosting instructions
LIVEKIT_URL=wss://your-livekit-server.com
LIVEKIT_API_KEY=your_livekit_api_key_here
LIVEKIT_API_SECRET=your_livekit_api_secret_here

# Voice AI Configuration (Required for Restaurant Booking Voice AI agent)
# Deepgram API Key (Required for STT/TTS in restaurant_agent.py)
# Get from: https://console.deepgram.com/
# Free tier available for testing
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# ElevenLabs API Key (Optional - alternative TTS provider)
# Get from: https://elevenlabs.io/
# Uncomment if you want to use ElevenLabs instead of Deepgram for TTS
# ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Image Generation Configuration (for Image to Coloring Book converter)
# Model for image-to-image generation
# For Fireworks AI: accounts/fireworks/models/flux-kontext-pro (image-to-image workflow)
# For OpenAI: gpt-image-1 (supports image-to-image via edit API)
IMAGE_MODEL=accounts/fireworks/models/flux-kontext-pro

# Vision Model Configuration (for Invoice Parser)
# Recommended: gemini-2.0-flash-exp (Google) or gpt-4o (OpenAI) or accounts/fireworks/models/qwen-vl-max (Fireworks)
VISION_MODEL=gemini-2.0-flash-exp

# Browser Automation Configuration (for Amazon Product Shopping demo)
# Chrome DevTools Protocol URL for browser-use automation
# Default: http://localhost:9222 (automatically started by 'make dev')
# For Docker: http://host.docker.internal:9222 (set automatically in docker-compose.yml)
# Only set this if you need a custom CDP URL
# BROWSER_CDP_URL=http://localhost:9222

# Other API Keys (add as needed)
# ANTHROPIC_API_KEY=your_anthropic_key_here

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
