# LLM Provider Configuration
# Priority: FIREWORKS_API_KEY > OPENROUTER_API_KEY > GEMINI_API_KEY > OPENAI_API_KEY
# Set LLM_PROVIDER to force a specific provider: "fireworks", "openrouter", "gemini", "openai"

# FireworksAI (recommended for best performance)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_MODEL=accounts/fireworks/models/qwen3-235b-a22b-instruct-2507

# OpenRouter (access to many models including Claude, GPT-4, Llama, etc.)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=minimax/minimax-m2:free

# Google Gemini (free tier available)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
